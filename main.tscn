[sub_resource type="GDScript" id="GDScript_1bvp3"]
script/source = "extends HBoxContainer

@export var minimum_width = 32

func _ready() -> void:
	%Controls_Sidebar/Box.hide()
	%Indicators_Sidebar/Box.hide()
	%Controls_Sidebar.custom_minimum_size.x = minimum_width
	%Indicators_Sidebar.custom_minimum_size.x = minimum_width


func _on_controls_sidebar_mouse_entered() -> void:
	var final_size = %Controls_Sidebar/Box.size.x
	%Controls_Sidebar/Box.show()
	var tween = create_tween()
	tween.set_trans(Tween.TRANS_ELASTIC).set_ease(Tween.EASE_OUT)
	tween.tween_property(%Controls_Sidebar, \"custom_minimum_size:x\", final_size, 1).from_current()
func _on_controls_sidebar_mouse_exited() -> void:
	if not %Controls_Check.button_pressed:
		var tween = create_tween()
		tween.set_trans(Tween.TRANS_EXPO)
		tween.tween_property(%Controls_Sidebar, \"custom_minimum_size:x\", minimum_width, 0.5).from_current()
		tween.chain().tween_callback(%Controls_Sidebar/Box.hide)


func _on_indicators_sidebar_mouse_entered() -> void:
	var final_size = %Indicators_Sidebar/Box.size.x
	%Indicators_Sidebar/Box.show()
	var tween = create_tween()
	tween.set_trans(Tween.TRANS_ELASTIC).set_ease(Tween.EASE_OUT)
	tween.tween_property(%Indicators_Sidebar, \"custom_minimum_size:x\", final_size, 1).from_current()
func _on_indicators_sidebar_mouse_exited() -> void:
	if not %Indicators_Check.button_pressed:
		var tween = create_tween()
		tween.set_trans(Tween.TRANS_EXPO)
		tween.tween_property(%Indicators_Sidebar, \"custom_minimum_size:x\", minimum_width, 0.5).from_current()
		tween.chain().tween_callback(%Indicators_Sidebar/Box.hide)
"

