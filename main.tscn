[sub_resource type="GDScript" id="GDScript_h2yge"]
script/source = "@tool
extends Flowchart

@export var appearance : FlowchartStyle : 
	set(val):
		appearance = val
		if val != null:
			val.changed.connect(_on_appearance_changed)
			_on_appearance_changed()

func _on_appearance_changed():
	cell_size = appearance.cell_size
	min_cell_size = appearance.min_cell_size
	grid_thick = appearance.grid_thick
	orig_thick = appearance.orig_thick
	grid_color = appearance.grid_color
	orig_color = appearance.orig_color
	color = appearance.color


func _ready() -> void:
	super()
	
	if appearance == null:
		appearance = FlowchartStyle.new()
	
	$PopupMenu.index_pressed.connect(_on_popup_menu_pressed.bind(0))
	$PopupMenu.clear(true)
	var idx = -1
	for each in popup_devices:
		idx += 1
		if popup_devices[each] is Dictionary:
			var submenu = PopupMenu.new()
			$PopupMenu.add_submenu_node_item(each, submenu)
			submenu.index_pressed.connect(_on_popup_menu_pressed.bind(idx))
			for subeach in popup_devices[each]:
				submenu.add_item(subeach)
		else:
			$PopupMenu.add_item(each)

func _gui_input(event: InputEvent) -> void:
	super(event)
	
	if event is InputEventMouseButton:
		if event.button_index == MOUSE_BUTTON_LEFT:
			if event.is_released():
				var grabbed = G.grabbed_buttons.get_pressed_button()
				if not grabbed == null:
					add_graph_node(grabbed.get_meta(\"path\"), to_canvas_coord(fin_mouse))



var popup_devices = {
	\"Info Panel\": \"res://module/InfiCanvas/Flowchart/Nodes/info_panel.tscn\",
	\"Cabling\":\"res://modules/InfiCanvas/Flowchart/Nodes/cabling.tscn\",
	#\"Ammeter\"
	#\"Voltmeter\"
	#\"Heartbeat\": \"res://module/InfiCanvas/Flowchart/Nodes/heartbeat.tscn\",
	}
func _on_popup_menu_pressed(idx:int, submenu:int) -> void:
	var press_text : String
	if submenu > 0:
		press_text = $PopupMenu.get_item_submenu_node(submenu).get_item_text(idx)
		add_graph_node(popup_devices[$PopupMenu.get_item_text(submenu)][press_text])
	else:
		press_text = $PopupMenu.get_item_text(idx)
		add_graph_node(popup_devices[press_text])
"

