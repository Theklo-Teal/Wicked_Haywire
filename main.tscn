[sub_resource type="GDScript" id="GDScript_0xm2m"]
script/source = "extends Node

#TODO Mode button switches visibility of Component tray versus Analyser tray, so components can't be placed during simulation mode.

@export_storage var schematic : Schematic
@export_storage var initial_traytab = 4
@export_storage var split_container = 180 : 
	set(val):
		split_container = val
		if not is_node_ready():
			await ready
			%TraySplitter.split_offsets[0] = val

func _ready() -> void:
	if schematic == null:
		schematic = Schematic.new()
	
	%TrayTabBar.current_tab = initial_traytab
	%Ribbon/TabContainer.current_tab = initial_traytab
	
	find_flowchart_style()
	%Cell_Size.value_changed.connect( func(val):%Flowchart.appearance.cell_size = val )
	%Grid_Thick.value_changed.connect( func(val):%Flowchart.appearance.grid_thick = val )
	%Orig_Thick.value_changed.connect( func(val):%Flowchart.appearance.orig_thick = val )
	%Grid_Color.color_changed.connect( func(val):%Flowchart.appearance.grid_color = val )
	%Orig_Color.color_changed.connect( func(val):%Flowchart.appearance.orig_color = val )
	%Back_Color.color_changed.connect( func(val):%Flowchart.appearance.color = val )
	
	find_electronics_parts()

func _input(event: InputEvent) -> void:
	if event is InputEventKey and event.is_released():
		match event.keycode:
			KEY_F1:
				%Mode.button_pressed = not %Mode.button_pressed
			KEY_ESCAPE:
				var grab_part = G.grabbed_buttons.get_pressed_button()
				if not grab_part == null:
					grab_part.button_pressed = false
					return


#region Flowchart Style Management
func find_flowchart_style():
	%Cell_Size.value = %Flowchart.cell_size
	%Grid_Thick.value = %Flowchart.grid_thick
	%Orig_Thick.value = %Flowchart.orig_thick
	%Grid_Color.color = %Flowchart.grid_color
	%Orig_Color.color = %Flowchart.orig_color
	%Back_Color.color = %Flowchart.color

#endregion

#region Ribbon/Tray

func _on_tray_tab_bar_tab_changed(tab: int, tabbar: TabBar) -> void:
	if tab < 0:
		%Ribbon.hide()
	else:
		%Ribbon.show()
		var tabtitle = tabbar.get_tab_title(tab)
		%Ribbon/TabContainer.find_child(tabtitle, false).show()

#region Electronics Components Tray

func find_electronics_parts():
	const dev_path = \"res://devices/\"
	for dev_category : String in parts_categories:
		var open_button := Button.new()
		parts_categories[dev_category].append(open_button)
		
		open_button.text = dev_category.capitalize()
		open_button.pressed.connect(_on_part_category_toggle.bind(dev_category, true))
		
		%part_categories.add_child(open_button)
		
		var box := VBoxContainer.new()
		var close_button := Button.new()
		var innerbox := VFlowContainer.new()
		parts_categories[dev_category].append(close_button)
		parts_categories[dev_category].append(box)
		
		box.size_flags_vertical = Control.SIZE_EXPAND_FILL
		close_button.text = dev_category.capitalize()
		close_button.size_flags_horizontal = Control.SIZE_SHRINK_BEGIN
		innerbox.size_flags_vertical = Control.SIZE_EXPAND_FILL
		innerbox.add_theme_constant_override(\"v_separation\", 0)
		box.hide()
		
		close_button.pressed.connect(_on_part_category_toggle.bind(dev_category, false))
		
		%Components.add_child(box)
		box.add_child(close_button)
		box.add_child(innerbox)
		for dev in DirAccess.get_files_at(dev_path.path_join(dev_category)):
			if dev.get_extension() == \"uid\":
				continue
			var full_path = dev_path.path_join(dev_category).path_join(dev)
			#var part = load(full_path) #TODO load all components at start up.
			#G.part_pallet.append(part)
			var dev_button := Button.new()
			dev_button.text = dev.get_basename().capitalize()
			dev_button.set_meta(\"path\", full_path)
			#dev_button.set_meta(\"refer\", part)
			dev_button.flat = true
			dev_button.toggle_mode = true
			dev_button.button_group = G.grabbed_buttons
			innerbox.add_child(dev_button)

var parts_categories = {
	\"misc\" : [],
	\"input\" : [],
#	\"output\" : [],
	\"checks\" : [],
#	\"arithmetic\" : [],
#	\"plexers\" : [],
#	\"memory\" : [],
	}

func _on_part_category_toggle(category:String, show:bool):
	parts_categories[category][0].visible = not show
	parts_categories[category][1].visible = show
	parts_categories[category][2].visible = show

func _on_fold_devices_toggled(toggled_on: bool, butt:Button) -> void:
	butt.text = [\"Unfold All\", \"Fold All\"][int(toggled_on)]
	for category in parts_categories:
		_on_part_category_toggle(category, toggled_on)
#endregion

#endregion

func _on_sidebar_button_toggled(toggled_on: bool) -> void:
	%Sidebar.visible = toggled_on

func _on_sim_paused_toggled(toggled_on: bool, butt:Button) -> void:
	butt.text = [\"Paused\", \"Running\"][int(toggled_on)]
	butt.modulate = [Color.RED, Color.LIME_GREEN][int(toggled_on)]
	%Flowchart.call([\"pause_sim\", \"resume_sim\"][int(toggled_on)])


func _on_sim_rate_item_selected(index: int, butt:OptionButton) -> void:
	var hz = butt.get_item_id(index) as float
	%Flowchart.update_rate = 1.0 / hz


#region Schematic Layers
func scheme_add_layer(title:String=\"\"):
	if title.is_empty():
		title = \"Layer_\" + str(%Scheme_Layers.tab_count)
	%Scheme_Layers.add_tab(title)
	schematic.graphs[title] = FlowchartGraphElectronics.new()

var scheme_layer_delete_target : String
func _on_scheme_layers_tab_close_pressed(tab: int) -> void:
	scheme_layer_delete_target = %Scheme_Layers.get_tab_title(tab)
	if Input.is_key_pressed(KEY_CTRL):
		scheme_rem_layer()
	else:
		$Confirm_Rem_Layer.dialog_text = \"Are you sure you want to delete layer «\" + scheme_layer_delete_target + \"»?\"
		$Confirm_Rem_Layer.popup()
func scheme_rem_layer(target:String=\"\"):
	if target.is_empty():
		target = scheme_layer_delete_target
	var target_idx : int = -1
	for i in range(%Scheme_Layers.tab_count):
		if %Scheme_Layers.get_tab_title(i):
			target_idx = i
			break
	
	if target_idx > 0:
		%Scheme_Layers.remove_tab(target_idx)
		schematic.graphs.erase(target)
		schematic.styles.erase(target)
	
	if %Scheme_Layers.tab_count == 0:
		scheme_add_layer(\"Layer_Zero\")
#endregion


func _on_tray_splitter_drag_ended(splitter: SplitContainer) -> void:
	split_container = splitter.split_offsets[0]


func _on_mode_toggled(toggled_on: bool, button:Button) -> void:
	%Flowchart.mode = int(toggled_on) as Flowchart.Mode
	button.text = [\"Place\", \"Poke\"][int(toggled_on)]
"

