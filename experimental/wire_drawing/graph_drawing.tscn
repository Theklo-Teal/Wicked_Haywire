script/source = "extends Control

var net := xNetwork.new()
var ref_sock : xSocket  ## A selected xSocket
var ref_wire : xNetwork.xWire  ## selected xNetwork.xWire
var ref_segm : xWireSegm ## Selected Segment
var segm_info : Dictionary  ## Information on the selected segment.

var start_drag : Vector2
var was_dragging : bool
func _gui_input(event: InputEvent) -> void:
	if event is InputEventMouseMotion:
		queue_redraw()
		if Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT) or Input.is_mouse_button_pressed(MOUSE_BUTTON_RIGHT):
			was_dragging = true
	
	if event is InputEventKey and not event.is_echo():
		match event.keycode:
			KEY_SHIFT:
				if was_dragging:
					# Change the orientation of wire being created.
					queue_redraw()
			KEY_DELETE:
				pass
	
	if event is InputEventMouseButton:
		if event.is_pressed():
			queue_redraw()
			start_drag = event.position
			ref_sock = null
			ref_wire = null
			ref_segm = null
			if net.get_socket(event.position) == null:
				# If not pressing over a socket, select a wire.
				_mouse_over_segment(event.position)
			if ref_segm == null:
				# If no wire is pressed on, add a socket, if it doesn't exit at that place.
				ref_sock = net.add_socket(event.position)
		elif event.is_released():
			match event.button_index:
				MOUSE_BUTTON_LEFT:
					# Create wire
					if was_dragging:
						var ori_sock = ref_sock
						if ori_sock != null:  #TODO Figure out how can ori_sock be null.
							ref_sock = net.add_socket(event.position)
							ref_segm = net.add_wire_segm(ori_sock, ref_sock, Input.is_key_pressed(KEY_SHIFT))
							ref_wire = ref_segm.wire
					was_dragging = false
					queue_redraw()
				MOUSE_BUTTON_RIGHT:
					# Move wire
					was_dragging = false
					queue_redraw()

func _mouse_over_segment(where:Vector2):
	ref_wire = null
	ref_segm = null
	for wire in net.list:
		var found = wire.find_segment(where)
		if found.size() == 0:
			continue
		if found.size() == 1:
			segm_info = found[0].near(where)
			if not segm_info.is_empty():
				ref_segm = found[0]
				ref_wire = wire
				break
		else:  #TODO Allow user to click multiple times to select a different overlapping segment.
			segm_info = found[0].near(where)
			if not segm_info.is_empty():
				ref_segm = found[0]
				ref_wire = wire

func _draw() -> void:
	for sock in net.sockets.values():
		sock.draw(self, ref_sock == sock)
	
	# Cell Highlight
	if not was_dragging:
		var clr = Color.WHITE
		clr.a = 0.3
		var grid = X.to_grid(get_local_mouse_position())
		draw_circle(grid.cell_position, X.CELL_RAD, clr)
	
	for wire in net.list:
		wire.draw(self, ref_segm)
	
	if was_dragging and ref_sock != null:
		var rect = Rect2(ref_sock.position, get_local_mouse_position() - ref_sock.position)
		xWireSegm.draw_length(self, rect, Input.is_key_pressed(KEY_SHIFT), xWireSegm.BEND, Color.GOLD)

