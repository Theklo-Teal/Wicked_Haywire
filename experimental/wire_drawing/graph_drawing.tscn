[sub_resource type="GDScript" id="GDScript_u6phq"]
script/source = "extends Control

#TODO Ensure no wires are created where there is already a connection.
#TODO Allow cycling selection through overlapping wires.
#TODO Wire deletion
#TODO Wire detach
#TODO Wire split
#TODO Wire join
#TODO Wire shifting (tentative)
#TODO Wire merge (tentative)

var net := xNetwork.new()

func _ready() -> void:
	for i in range(20):
		var coord = Vector2i(1, i + 5)
		var sock = xSocket.new()
		sock.mode = xSocket.INPUT if i % 2 == 0 else xSocket.OUTPUT
		net.register_joint(sock, X.layer, coord)

func _mouse_over_joint(where:Vector2):
	var cell = X.to_grid(where).coord
	cell = Vector3i(cell.x, cell.y, X.layer)
	X.coord_joint = cell
	X.sel_joint = net.netlist.joints.get(cell)

func _mouse_over_wire(where:Vector2):
	X.sel_wire = null
	for wire in net.netlist.wires[X.layer]:
		X.info_wire = wire.near(where)
		if not X.info_wire.is_empty():
			X.sel_wire = wire
			X.info_wire[\"bend\"] = X.sel_wire.bend
			break

func _resize_bend(wire:xWire, ini_bend:float, ini_pos:Vector2, end_pos:Vector2):
		var verts = wire.get_verts()
		var short_vert = wire.get_leg(false)
		var rect = wire.get_rect()
		var axis = rect.size.min_axis_index()
		var dir = 1 if ini_pos[axis] > verts[short_vert][axis] else -1
		var delta = end_pos - ini_pos
		var dist : float = delta.length() * delta.sign()[axis] * dir
		dist /= rect.size[axis]
		wire.bend = clamp(ini_bend + dist, 0, 1) 


var start_drag : Vector2
var was_drag : bool
func _gui_input(event: InputEvent) -> void:
	if event is InputEventKey and not event.is_echo():
		match event.keycode:
			KEY_SHIFT:
				if was_drag:
					# Change the orientation of wire being created.
					queue_redraw()
			KEY_DELETE:
				if X.sel_wire != null:
					# Delete wire selected.
					pass
			KEY_ESCAPE:
				if was_drag and X.sel_wire != null:
					# Delete wire being pulled.
					pass
	
	if event is InputEventMouseMotion:
		queue_redraw()  # Redraw to show cell indicator
		if Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT) or Input.is_mouse_button_pressed(MOUSE_BUTTON_RIGHT):
			was_drag = true
		if Input.is_mouse_button_pressed(MOUSE_BUTTON_RIGHT) and X.sel_wire != null:
			if floor(X.info_wire.subratio) == 1:  # Clicked on Bend
				_resize_bend(X.sel_wire, X.info_wire.bend, start_drag, event.position)
			#else:
				## Detach Wire
				#if segm_info.subratio < 1:
					#ref_segm.ori_position = event.position
				#else:
					#ref_segm.end_position = event.position
	
	if event is InputEventMouseButton:
		if event.is_pressed():
			queue_redraw()
			start_drag = event.position
			_mouse_over_joint(event.position)
			#if net.get_socket(event.position) == null:
				## If not pressing over a socket, select a wire.
				#_mouse_over_wire(event.position)
			#if X.sel_wire == null and event.button_index == MOUSE_BUTTON_LEFT:
				## If no wire is pressed on, add a socket, if it doesn't exit at that place.
				#X.sel_joint = net.add_socket(event.position)
			#elif X.sel_wire != null:  # A segment was found and selected
				#if event.button_index == MOUSE_BUTTON_LEFT:
					## Split wire
					#pass
				#elif event.button_index == MOUSE_BUTTON_RIGHT:
					## Detach wire
					#if floor(X.info_wire.subratio) != 1:  # Not clicking on a bend.
						#X.sel_joint = X.info_wire.socket
		elif event.is_released():
			if was_drag:
				was_drag = false
				queue_redraw()
				match event.button_index:
					MOUSE_BUTTON_LEFT:
						var ori_joint = X.sel_joint
						if ori_joint != null:
							# Create wire
							X.sel_joint = xVia.new()
							net.register_joint(X.sel_joint, X.layer, X.to_grid(event.position).coord)
							X.sel_wire = xWire.from_length(ori_joint, X.sel_joint, Input.is_key_pressed(KEY_SHIFT))
							net.register_wire(X.sel_wire, X.layer)
					#MOUSE_BUTTON_RIGHT:
						#if not X.info_wire.is_empty() and floor(X.info_wire.subratio) != 1:
							#var ori_sock = X.info_wire.socket
							#if ori_sock != null:
								## Create wire
								#X.sel_joint = net.add_socket(event.position)
								#X.sel_wire = net.add_wire(ori_sock, X.sel_joint, Input.is_key_pressed(KEY_SHIFT))


func _draw() -> void:
	# Draw stuff on the netlist
	for coord in net.netlist.joints:
		if coord.z != X.layer:
			continue
		var joint = net.netlist.joints[coord]
		joint.position = X.from_grid(Vector2i(coord.x, coord.y))
		joint.draw(self, joint == X.sel_joint)
	for wire in net.netlist.wires.get(X.layer, []):
		wire.draw(self, wire == X.sel_wire)
	
	## Cell Highlight
	if not was_drag:
		var clr = Color.WHITE
		clr.a = 0.3
		var grid = X.to_grid(get_local_mouse_position())
		draw_circle(grid.position, X.CELL_RAD, clr)
	
	# Wire being pulled
	if was_drag and X.sel_joint != null:
		var start = X.from_grid(Vector2i(X.coord_joint.x, X.coord_joint.y))
		var stop = X.to_grid(get_local_mouse_position()).position
		var rect = Rect2(start, stop - start)
		xWire.draw_length(self, rect, Input.is_key_pressed(KEY_SHIFT), Color.YELLOW)


var period : float = 0.33
var _elapsed : float = 0
func _process(delta: float) -> void:
	_elapsed += delta
	if _elapsed > period:
		_elapsed = 0
		net.setup_cycle()
		net.setup_cycle()
		net.finish_cycle()
"

