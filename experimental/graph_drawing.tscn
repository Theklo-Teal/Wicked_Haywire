[sub_resource type="GDScript" id="GDScript_u6phq"]
script/source = "extends Control

## New idea for a wiring system. Sockets have a world relative position
## (or relative to their nodes, then have world position) and act as anchors
## to wire segments, which have position relative to other connected wires,
## or if connected to Sockets, it's relative to those sockets.
## When clicking on a wire, we test which wires have rects containing the mouse
## and on each of the wires, which of their segments are under the mouse.
## Then whether it's a side of a segment's rect or a end. If a side, we do a resizing
## operation. If it's an end, then we extend the wire with a new segment.

#TODO Maybe have staggered socket locations?

const CELL = 10
const BEND = 0.5

var ref_sock : Socket  ## A selected Socket
var ref_wire : Wire  ## selected Wire
var ref_segm : Wire_Segm ## Selected Segment
var segm_op : int  ## The operation being performed on a segment
var sockets : Array[Socket]
var netlist : Dictionary[Wire, Port]  ## Isolated graphs and the signal ports associated. If [code]Port[/code] is null, the graph needs updating.

class Port:
	var value
	var aggregate : Array
	func integrate():
		value = aggregate.reduce(func(sum, a):return sum + a, 0)
	func read():
		return value
	func write(val):
		aggregate.append(val)

class Socket:
	## Anchors to world coordinate for Segments
	var position: Vector2
	var temporary := false
	var wire : Wire
	var default := 0
	func _init(where:Vector2, wire_end:=false):
		position = where
		temporary = wire_end
	func get_port() -> Port:
		if wire == null:
			return null
		return wire.get_port()
	func emit(val):
		var port = get_port()
		if port != null:
			port.write(val)
	func query():
		var port = get_port()
		if port == null:
			return default
		else:
			return port.read()
	
	func draw(canvas:Control, highlight:=false):
		if highlight:
			canvas.draw_circle(position, CELL, Color.BISQUE, false, CELL / 3.0)
		canvas.draw_circle(position, CELL / 2.0, Color.GOLD, false, CELL / 2.5)
	
	func near(point:Vector2) -> bool:
		# This is what you call a window comparison. Faster than vector distance that requires square roots.
		var rect = Rect2(position - Vector2(0.5, 0.5) * CELL, Vector2.ONE * CELL)
		return rect.has_point(point)

class Wire:
	var netlist : Dictionary[Wire, Port]
	var rect : Rect2
	var segms : Array[Wire_Segm]
	
	func _init(network:Dictionary[Wire, Port]) -> void:
		netlist = network
	
	func get_port() -> Port:
		return netlist.get(self)
	
	func draw(canvas:Control, selected:Wire_Segm):
		for each in segms:
			each.draw(canvas, each == selected)
	
	## Returns a list of segments which [code]Wire_Segm.rect[/code] contains [code]point[/code].[br]
	## Returns empty if the point is outside this Wire's [code]rect[/code].
	func find_segment(point:Vector2) -> Array[Wire_Segm]:
		#NOTE we grow the rects, because the drawn line is split lengthwise,
		# where half of it is outside the rect. We want the user to be able to
		# select by clicking anywhere on the visible line.
		var matches : Array[Wire_Segm]
		if not rect.grow(CELL / 2.0).has_point(point):
			return []
		for segm in segms:
			if segm.rect.grow(CELL / 2.0).has_point(point):
				matches.append(segm)
		return matches
	
	## Removes a wire segment from this wire. If the segment isn't found, returns
	## [code]ERR_DOES_NOT_EXIST[/code]. If the wire runs out of segments, it returns
	## [code]ERR_TIMEOUT[/code] and deletes its [code]Port[/code] as a sign to
	## update and eventual deletion of the wire itself.
	func delete(segm:Wire_Segm) -> Error:
		if not segm in segms:
			return ERR_DOES_NOT_EXIST
		segms.erase(segm)
		if segms.is_empty():
			# Mark for deletion of the wire in the network.
			netlist[self] = null
			return ERR_TIMEOUT
		return OK
	
	## Add segments to wires. If a graph is connected to another, they are merged as a single graph.
	func extend(segm:Wire_Segm):
		var min_axis = segm.rect.size.min_axis_index()
		if segm.rect.size[min_axis] <= CELL:
			pass
			# We are drawing a straight line
		rect = rect.merge(segm.rect)
		segms.append(segm)

class Wire_Segm:
	var rect : Rect2
	var corners : Array[CORN]  ## Sequence of corners of the rectangle the wire runs along.
	var bend : float = BEND  ## From 0 to 1, how far along the shortest end should a diagonal be done cutting the corner.
	var ori_conn : Array[Wire_Segm]  ## Other segments connected to the first corner of this one.
	var end_conn : Array[Wire_Segm]  ## Other segments connected to the last corner of this one.
	var socket_ori : Vector2  ## If ori_conn is empty, refer to socket
	var socket_end : Vector2  ## if end_conn is empty, refer to socket
	var color := Color.GOLDENROD
	var alt_color := Color.BISQUE
	
	enum CORN {
		TOPLEFT,
		BOTLEFT,
		TOPRIGHT,
		BOTRIGHT,
		}
	
	
	const ORIENT = {  ## The orientation of a line connecting the given corners.
		[1,3] : 0,
		[0,2] : 0,
		[0,1] : 1,
		[2,3] : 1,
	}
	
	func _init(box:Rect2, ori:CORN, mid:CORN, end:CORN) -> void:
		rect = box.abs()
		corners = [ori, mid, end]
	
	## Get a wire segment knowing the winding direction.
	static func from_chiral(start:Vector2, stop:Vector2, clockwise:bool) -> Wire_Segm:
		var r = Rect2(start, stop - start)
		var corns = get_corners(r.size, clockwise)
		return Wire_Segm.new(r, corns[0], corns[1], corns[2])
	
	## Get a wire segment knowing we want the first line to be either the longest or shortest.
	static func from_length(start, stop, short:bool) -> Wire_Segm:
		var box = Rect2(start, stop - start)
		var last = last_corner(box.size)
		var chiral = get_chirality(short, last, box.size.abs())
		var corns = get_corners(box.size, chiral)
		return Wire_Segm.new(box, corns[0], corns[1], corns[2])
	
	## Returns a dictionary of the total [code]length[/code] of the wire,
	## [code]distance[/code] along the wire in absolute value, and as a
	## [code]ratio[/code] of them.[br]
	## Ratio can be between 0 (first corner) and 1 (last corner).[br]
	## Returns empty if the point is not over the lines drawn by the wire segment.
	## This includes around the mid corner, if there's a diagonal bend so nothing
	## drawn there.
	func near(point:Vector2) -> Dictionary[String, float]:
		var verts = get_verts()
		
		## New Method
		var bends = get_verts(true)
		var solved : bool  # A segment under the point has been found.
		var total : float = 0.0  # Total wire length.
		var accum : float = 0.0  # Accumulated distance along the path to the point.
		for c in range(bends.size() - 1):
			var n = c + 1 % bends.size()
			var v1 = verts[c]
			var v2 = verts[n]
			var segm = v1 - v2
			var rel = (v1 - point)
			var direct = segm.normalized()
			var normal = Saliko.perpendicular(direct)
			var leng = direct.dot(segm)  # Length of segment.
			var dist = direct.dot(rel)  # Distance of point along the segment.
			var along = inverse_lerp(0, leng, dist)  # Distance as a value from 0 to 1.
			var prox = abs(normal.dot(rel))  # Proximity to the segment.
			total += leng
			if solved:
				# Even after finding a matching segment,we keep iterating through
				# all segments so we can find the total length of the wire.
				continue
			if along < 1 and along > 0 and prox < CELL / 2.0:
				# We don't want to accept distances further than a segment's
				# length, which happens when clicking near the mid corner as if
				# bend ratio was 1.
				solved = true
				accum += dist  # Earlier segment distances + distance along this segment.
			else:
				accum += leng  # Account rejected segm distance.
		
		if not solved:
			return {}
		return {
			\"distance\": accum,
			\"length\": total,
			\"ratio\": inverse_lerp(0, total, accum) }
		
	
	## Get the positions of corners this wire segment runs along.
	func get_verts(with_bend:=false) -> PackedVector2Array:
		return find_verts(rect, corners[0], corners[1], corners[2], bend)
	
	## Orientation of a connection.[br]
	## Which axis does the line connected to the given end runs along? [br]
	## This returns a bitfield where the least significant digit encodes the axis,
	## In the same convention as the notation [code]Vector2[axis][/code]:
	## 0 -> horizontal, 1 -> vertical. The most second digit is the direction:
	## 0 -> negative, 1 -> positive.[br]
	## So 0b10 would be +X orientation, 0b01 is -Y, for example.[br]
	## This returns -1 if the corner indexes are invalid and can't represent a
	## valid wire. This can be used to check if the segment instance represents
	## a valid sequence.
	@warning_ignore(\"shadowed_variable\")
	func conn_orient(last_corner:bool=false) -> int:
		# By summing the selected end corner with the mid corner, we get a unique
		# number to every possible permutation, which then can be used as the index
		# of a lookup table.
		var selected_end = [corners[0], corners[2]][int(last_corner)]
		var segmsum = selected_end + corners[1]
		if selected_end == corners[1] or segmsum in [0,3]:
			# The same corner as mid is selected or 
			# opposite corners selected, which shouldn't be possible.
			return -1
		return [1,0,-1,0,1][segmsum - 1] | int(selected_end > corners[1]) << 1
	
	## Get the winding direction such as the the first line is either longest or shortest.
	## box_size must be positive (abs() applied).
	static func get_chirality(short_first:bool, end:CORN, box_size:Vector2) -> bool:
		var axis = bool(box_size.min_axis_index()) != short_first
		return [true,false,false,true][end] != axis
	
	## With the size of a Rect2 without abs(), get the order of corners the wire runs along.
	static func get_corners(raw_size:Vector2, clockwise:bool) -> Array[CORN]:
		var end = last_corner(raw_size)
		var seq : Array[CORN] = [
			abs(end - 3) as CORN, 
			[[1, 3, 0, 2],[2, 0, 3, 1]][int(clockwise)][end] as CORN,
			end ]
		return seq
	
	static func last_corner(raw_size:Vector2):
		var x = int(raw_size.x > 0)
		var y = int(raw_size.y > 0)
		return ((x << 1) | y ) as CORN
	
	## Returns the length away from the mid corners that bend vertices appear.
	## The box must have positive size.
	static func find_bend_distance(box:Rect2, ratio:float) -> float:
		return min(box.size.x, box.size.y) * ratio
	
	## Finds the vertices to draw a line according to given corners.[br]
	## The [code]box[/code] rect must have positive size.[br]
	## In agreement with [code]bend[/code], [code]ratio[/code] is a value between
	## 0 and 1. If more than 0, it provides vertices to produce a diagonal segment.
	## Otherwise, only the vertex at the mid corner is provided.
	static func find_verts(box:Rect2, ori:CORN, mid:CORN, end:CORN, ratio:float=-1) -> PackedVector2Array:
		var box_verts = [  # Coordinates of all vertices of the box.
			box.position,
			Vector2(box.position.x, box.end.y),
			Vector2(box.end.x, box.position.y),
			box.end ]
		
		var verts = [
			box_verts[ori],
			box_verts[end] ]
		
		if ratio < 0 or ratio >= 1:
			verts.insert(1, box_verts[mid])
			return verts
		
		var bend_dist = find_bend_distance(box, 1 - ratio)
		var bend_x = [  # bend point along the horizontal segment
			Vector2.RIGHT, Vector2.RIGHT, Vector2.LEFT, Vector2.LEFT
			][mid] * bend_dist
		var bend_y = [  # bent point along the vertical segment
			Vector2.DOWN, Vector2.UP, Vector2.DOWN, Vector2.UP
			][mid] * bend_dist
		
		# Finding which of the bend point is appropriate according to
		# orientation of segments from ori and segments from end.
		var ori_segm = [ori, mid]
		ori_segm.sort()
		ori_segm = [bend_x, bend_y][ORIENT[ori_segm]]
		var end_segm = [mid, end]
		end_segm.sort()
		end_segm = [bend_x, bend_y][ORIENT[end_segm]]
		
		verts.insert(1, end_segm + box_verts[mid])
		verts.insert(1, ori_segm + box_verts[mid])
	
		return verts
	
	## Draws this wire segment on canvas.
	func draw(canvas:Control, highlight:bool=false):
		draw_along(canvas, rect, corners[0], corners[1], corners[2], bend, alt_color if highlight else color)
	
	## Given a rectangle with positive size, draw a wire.
	static func draw_along(canvas:Control, box:Rect2, ori:CORN, mid:CORN, end:CORN, diagonal:float, clr:=Color.GOLDENROD):
		var verts = find_verts(box, ori, mid, end, diagonal)
		canvas.draw_polyline(verts, clr, CELL / 1.5)
	
	## Given a a rectangle without abs(), draw on canvas according to winding direction.
	static func draw_chiral(canvas:Control, box:Rect2, clockwise:bool, diagonal:float, clr:=Color.GOLDENROD):
		var c = get_corners(box.size, int(clockwise))
		draw_along(canvas, box.abs(), c[0], c[1], c[2], diagonal, clr)
	
	## Given a a rectangle without abs(), draw on canvas such as the first line is either the longest or shortest.
	static func draw_length(canvas:Control, box:Rect2, long:bool, diagonal:float, clr:=Color.GOLDENROD):
		var end = last_corner(box.size)
		var chiral = get_chirality(long, end, box.size.abs())
		draw_chiral(canvas, box, chiral, diagonal, clr)

func _find_hover_sock(point:Vector2):
	ref_sock = null
	for s in sockets:
		if s.near(point):
			ref_sock = s
			return

func _find_hover_segm(point:Vector2):
	ref_wire = null
	ref_segm = null
	if ref_sock == null:
		for wire in netlist:
			for segm in wire.find_segment(point):
				var dist = segm.near(point)
				if dist.is_empty(): continue
				ref_wire = wire
				ref_segm = segm
				return

var drag_start : Vector2
var was_drag := false
func _input(event: InputEvent) -> void:
	if event is InputEventKey:
		if event.keycode == KEY_SHIFT and not event.is_echo():
			queue_redraw()
		if event.keycode == KEY_DELETE and event.is_released():
			var error = ref_wire.delete(ref_segm)
			queue_redraw()
			if error != ERR_DOES_NOT_EXIST:
				ref_segm = null
			if error == ERR_TIMEOUT:
				ref_wire = null
	
	if event is InputEventMouseButton:
		if event.is_pressed():
			if event.button_index == MOUSE_BUTTON_LEFT:
				drag_start = event.position
				_find_hover_sock(event.position)  # Find socket at a drag start.
				if ref_sock != null:
					drag_start = ref_sock.position
				_find_hover_segm(event.position)
		elif event.is_released():
			if event.button_index == MOUSE_BUTTON_LEFT:
				queue_redraw()
				_find_hover_sock(event.position)  # Find socket at drag end.
				
				if was_drag:
					was_drag = false
					if drag_start.distance_to(event.position) > 16:
						# extend a wire
						if ref_sock == null:
							var new_sock = Socket.new(event.position.snappedf(CELL), true)
							sockets.append(new_sock)
							ref_sock = new_sock
						if ref_sock.get_port() == null:
							ref_sock.wire = Wire.new(netlist)
							netlist[ref_sock.wire] = Port.new()
						var alt = Input.is_key_pressed(KEY_SHIFT)
						ref_sock.wire.extend(Wire_Segm.from_length(drag_start, ref_sock.position, alt))
						
			elif event.button_index == MOUSE_BUTTON_RIGHT:
				sockets.append(Socket.new(event.position.snappedf(CELL)))
				queue_redraw()
	
	if event is InputEventMouseMotion:
		if Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT) and ref_sock != null:
			was_drag = true
			queue_redraw()  # Display dragged wire

func _draw() -> void:
	for sock in sockets:
		sock.draw(self, ref_sock == sock)
	
	for wire in netlist:
		wire.draw(self, ref_segm)
	
	if Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT) and ref_sock != null:
		var rect = Rect2(drag_start, get_local_mouse_position() - drag_start)
		Wire_Segm.draw_length(self, rect, Input.is_key_pressed(KEY_SHIFT), BEND, Color.BISQUE)
"

[node name="Control" type="Control" unique_id=670497810]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = SubResource("GDScript_u6phq")
