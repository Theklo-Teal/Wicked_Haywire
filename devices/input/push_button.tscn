[sub_resource type="GDScript" id="GDScript_a8wdm"]
script/source = "@tool
extends Electronics

@export var slider : StyleBox : 
	set(val):
		slider = val
		queue_redraw()
		if not val.changed.is_connected(queue_redraw):
			val.changed.connect(queue_redraw)
@export var button_high : StyleBox : 
	set(val):
		button_high = val
		queue_redraw()
		if not val.changed.is_connected(queue_redraw):
			val.changed.connect(queue_redraw)
@export var button_low : StyleBox : 
	set(val):
		button_low = val
		queue_redraw()
		if not val.changed.is_connected(queue_redraw):
			val.changed.connect(queue_redraw)

enum Orient{
	RIGHT,
	DOWN,
	LEFT,
	UP
}

var orientation : Orient

func _ready() -> void:
	options[\"Rotate CW\"] = \"rotate_cw\"
	options[\"Rotate CCW\"] = \"rotate_ccw\"
	options[\"High Color\"] = \"high_color\"
	options[\"Low Color\"] = \"low_color\"

func rotate_cw():
	pass
func rotate_ccw():
	pass
func _set_high_color(val:Color):
	pass
func _set_low_color(val:Color):
	pass


func _update(graph:FlowchartGraph):
	graph.write($Source, $%Panel.high)


func _on_mouse_entered() -> void:
	%Header.show()
func _on_header_mouse_exited() -> void:
	%Header.hide()
"

