[sub_resource type="GDScript" id="GDScript_kysup"]
script/source = "extends Panel

@export var node : FlowchartNode

var high : bool
var pressed : bool
var latched : bool
var sliding : bool

func _gui_input(event: InputEvent) -> void:
	if event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_LEFT:
		queue_redraw()
		pressed = event.is_pressed()

func _draw() -> void:
	var button_box = [node.button_high, node.button_low][int(int(pressed) ^ int(latched))]
	var rect = Rect2(
		Vector2.ZERO,
		size
	)
	if latched:
		rect.position = size.x * 0.33
	draw_style_box(button_box, rect)
"

